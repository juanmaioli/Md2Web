<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Md2Web - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📚</text></svg>">

    <!-- Tema Dinámico -->
    <link id="themeLink" rel="stylesheet" href="<%= currentTheme === 'default' ? '' : '/themes/' + encodeURIComponent(currentTheme) + '/theme.css' %>">

    <style>
        :root {
            /* Variables por defecto estilo GitHub Dark si no hay tema */
            --background-primary: #0d1117;
            --background-secondary: #161b22;
            --text-normal: #f0f6fc;
            --text-muted: #8b949e;
            --text-accent: #58a6ff;
            --border-color: #30363d;
            --h1-color: #f0f6fc;
            --link-color: #58a6ff;
            --code-background: #161b22;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            height: 100vh;
            overflow: hidden;
            background-color: var(--background-primary) !important;
            color: var(--text-normal) !important;
            transition: all 0.3s ease;
        }

        .sidebar {
            height: 100vh;
            overflow-y: auto;
            border-right: 1px solid var(--border-color);
            background-color: var(--background-secondary) !important;
        }

        .content-area {
            height: 100vh;
            overflow-y: auto;
            padding: 2rem;
            background-color: var(--background-primary);
        }

        /* Mapeo de elementos Markdown a variables de tema de Obsidian */
        .markdown-rendered {
            line-height: 1.6;
            color: var(--text-normal);
        }
        .markdown-rendered h1 { color: var(--h1-color, var(--text-normal)); border-bottom: 1px solid var(--border-color); padding-bottom: 0.3em; margin-top: 24px; margin-bottom: 16px; }
        .markdown-rendered h2 { color: var(--h2-color, var(--text-normal)); border-bottom: 1px solid var(--border-color); padding-bottom: 0.3em; margin-top: 24px; margin-bottom: 16px; }
        .markdown-rendered h3 { color: var(--h3-color, var(--text-normal)); margin-top: 24px; margin-bottom: 16px; }
        .markdown-rendered p { margin-top: 0; margin-bottom: 16px; }
        .markdown-rendered a { color: var(--link-color, var(--text-accent)); text-decoration: none; }
        .markdown-rendered a:hover { text-decoration: underline; }
        .markdown-rendered code:not(pre code) { 
            background-color: var(--code-background, rgba(110,118,129,0.4)); 
            padding: 0.2em 0.4em; 
            border-radius: 6px; 
            font-family: ui-monospace, SFMono-Regular, SF Mono, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }
        .markdown-rendered pre { 
            background-color: var(--code-block-background, #161b22) !important; 
            padding: 16px; 
            border-radius: 6px; 
            overflow: auto; 
            border: 1px solid var(--border-color);
        }
        .markdown-rendered blockquote {
            padding: 0 1em;
            color: var(--text-muted);
            border-left: 0.25em solid var(--border-color);
            margin: 0 0 16px 0;
        }
        .markdown-rendered img { max-width: 100%; box-sizing: content-box; }
        .markdown-rendered table { border-spacing: 0; border-collapse: collapse; margin-bottom: 16px; width: 100%; }
        .markdown-rendered table th, .markdown-rendered table td { border: 1px solid var(--border-color); padding: 6px 13px; }
        .markdown-rendered table tr { background-color: var(--background-primary); border-top: 1px solid var(--border-color); }
        .markdown-rendered table tr:nth-child(2n) { background-color: var(--background-secondary); }

        .nav-link {
            padding: 0.5rem 1rem;
            border-radius: 6px;
            margin-bottom: 2px;
            color: var(--text-muted);
            transition: all 0.2s;
        }
        .nav-link:hover {
            background-color: var(--background-modifier-hover, rgba(255,255,255,0.05));
            color: var(--text-normal);
        }
        .nav-link.active {
            background-color: var(--text-accent, #1f6feb) !important;
            color: #ffffff !important;
        }

        /* Estilos TTS (Karaoke) */
        .tts-chunk {
            transition: background-color 0.2s, color 0.2s;
            padding: 1px 2px;
            border-radius: 4px;
            cursor: default;
        }
        .tts-active {
            background-color: rgba(255, 193, 7, 0.45);
            color: #fff;
            box-shadow: 0 0 8px rgba(255, 193, 7, 0.3);
        }
        [data-bs-theme="light"] .tts-active {
            background-color: rgba(255, 193, 7, 0.6);
            color: #000;
        }
    </style>
</head>
<body class="theme-dark">
    <!-- Modal de Lectura -->
    <div class="modal fade" id="modalLectura" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="container d-flex justify-content-between align-items-center">
                        <h5 class="modal-title">🎙️ Escuchando nota...</h5>
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center gap-2">
                                <small>Voz:</small>
                                <select id="voiceSelect" class="form-select form-select-sm border-0 bg-transparent fw-bold text-decoration-underline" style="width: auto;"></select>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                    </div>
                </div>
                <div class="modal-body p-5">
                    <div class="container" style="max-width: 800px;">
                        <h1 id="modalTitular" class="fw-bold mb-4"></h1>
                        <div id="modalCuerpo" class="fs-4 text-start"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid">

        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 sidebar p-3">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="m-0">📚 Md2Web</h4>
                </div>
                
                <!-- Selector de Temas -->
                <div class="mb-4">
                    <label class="form-label small text-secondary">🎨 Tema Visual</label>
                    <select id="themeSelector" class="form-select form-select-sm bg-dark text-light border-secondary">
                        <option value="default" <%= currentTheme === 'default' ? 'selected' : '' %>>GitHub Dark (Default)</option>
                        <% availableThemes.forEach(theme => { %>
                            <option value="<%= theme %>" <%= currentTheme === theme ? 'selected' : '' %>><%= theme %></option>
                        <% }); %>
                    </select>
                </div>

                <!-- Buscador -->
                <div class="mb-3">
                    <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="🔍 Buscar título...">
                    <div id="searchResults" class="list-group mt-2 position-absolute w-100 shadow" style="z-index: 1000; display: none;"></div>
                </div>

                <div id="fileTree">
                    <%- include('sidebar', { tree: tree, currentPath: currentPath }) %>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 col-lg-10 content-area">
                <div class="card shadow-sm p-4">
                    <%- body %>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>
        // Inicializar resaltado de sintaxis
        hljs.highlightAll();

        // Lógica de Live Reload
        const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
        const ws = new WebSocket(`${protocol}://${window.location.host}`);
        ws.onmessage = (event) => {
            const data = JSON.parse(event.data);
            if (data.type === 'reload') {
                // Solo recargar si el archivo abierto es el que cambió
                const currentFile = window.location.pathname.substring(1);
                if (decodeURIComponent(currentFile) === data.path) {
                    window.location.reload();
                }
            } else if (data.type === 'update') {
                // Actualizar sidebar para cualquier cambio estructural
                window.location.reload();
            }
        };

        // Lógica de Búsqueda
        const searchInput = document.getElementById('searchInput');
        const searchResults = document.getElementById('searchResults');

        // Lógica de cambio de tema
        const themeSelector = document.getElementById('themeSelector');
        const themeLink = document.getElementById('themeLink');

        themeSelector.addEventListener('change', async (e) => {
            const theme = e.target.value;
            
            // Actualizar CSS al vuelo
            if (theme === 'default') {
                themeLink.href = '';
            } else {
                themeLink.href = `/themes/${encodeURIComponent(theme)}/theme.css`;
            }

            // Guardar preferencia en el servidor
            await fetch('/api/settings/theme', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ theme })
            });
        });

        searchInput.addEventListener('input', async (e) => {
            const query = e.target.value;
            if (query.length < 2) {
                searchResults.style.display = 'none';
                return;
            }

            const response = await fetch(`/api/search?q=${query}`);
            const data = await response.json();
            
            if (data.length > 0) {
                searchResults.innerHTML = data.map(file => `
                    <a href="/${file.relative_path}" class="list-group-item list-group-item-action py-2">
                        📄 ${file.title}
                    </a>
                `).join('');
                searchResults.style.display = 'block';
            } else {
                searchResults.style.display = 'none';
            }
        });

        // Cerrar resultados al hacer clic fuera
        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.style.display = 'none';
            }
        });

        // --- Lógica TTS (Web Speech API) ---
        const btnEscuchar = document.getElementById('btnEscuchar');
        const modalLectura = new bootstrap.Modal(document.getElementById('modalLectura'));
        const modalTitular = document.getElementById('modalTitular');
        const modalCuerpo = document.getElementById('modalCuerpo');
        const voiceSelect = document.getElementById('voiceSelect');

        function cargarVoces() {
            const voices = window.speechSynthesis.getVoices();
            const spanishVoices = voices.filter(v => v.lang.startsWith('es'));
            
            voiceSelect.innerHTML = '';
            spanishVoices.forEach(voice => {
                const option = document.createElement('option');
                option.textContent = `${voice.name} (${voice.lang})`;
                option.value = voice.name;
                
                // Prioridad: Google español de EE.UU. > es-AR
                if (voice.name === 'Google español de Estados Unidos') {
                    option.selected = true;
                } else if (voice.lang === 'es-AR' && !voiceSelect.querySelector('[selected]')) {
                    option.selected = true;
                }
                
                voiceSelect.appendChild(option);
            });
        }

        if (window.speechSynthesis.onvoiceschanged !== undefined) {
            window.speechSynthesis.onvoiceschanged = cargarVoces;
        }
        cargarVoces();

        function leerTexto(texto, container, config = {}) {
            const { voiceName, rate = 1.0, pitch = 1.0 } = config;
            const audioChunks = [];
            const allSpans = [];
            container.innerHTML = '';

            const sentences = texto.match(/[^.!?\n]+[.!?\n]*/g) || [texto];
            sentences.forEach(s => {
                const cleanText = s.trim();
                if (cleanText.length > 0) {
                    const span = document.createElement('span');
                    span.className = 'tts-chunk';
                    span.innerText = s;
                    container.appendChild(span);
                    allSpans.push(span);
                    audioChunks.push(cleanText);
                }
            });

            window.speechSynthesis.cancel();
            let chunkIndex = 0;

            function hablarSiguiente() {
                if (chunkIndex >= audioChunks.length || !document.getElementById('modalLectura').classList.contains('show')) {
                    return;
                }

                allSpans.forEach(s => s.classList.remove('tts-active'));
                allSpans[chunkIndex].classList.add('tts-active');
                allSpans[chunkIndex].scrollIntoView({ behavior: 'smooth', block: 'center' });

                const utterance = new SpeechSynthesisUtterance(audioChunks[chunkIndex]);
                const voices = window.speechSynthesis.getVoices();
                const voice = voices.find(v => v.name === voiceSelect.value);
                if (voice) utterance.voice = voice;
                utterance.rate = rate;
                utterance.pitch = pitch;

                utterance.onend = () => {
                    chunkIndex++;
                    hablarSiguiente();
                };

                window.speechSynthesis.speak(utterance);
            }

            setTimeout(hablarSiguiente, 150);
        }

        if (btnEscuchar) {
            btnEscuchar.addEventListener('click', () => {
                const article = document.querySelector('.markdown-rendered');
                const titulo = document.querySelector('.breadcrumb-item.active')?.innerText || 'Nota';
                const contenido = article.innerText;

                modalTitular.innerText = titulo;
                modalLectura.show();
                leerTexto(contenido, modalCuerpo);
            });
        }

        document.getElementById('modalLectura').addEventListener('hidden.bs.modal', () => {
            window.speechSynthesis.cancel();
        });
    </script>
</body>
</html>
